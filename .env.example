# =============================================================================
# .env.example  —  ise copy karke ".env" banao aur values bharo (local dev).
# Railway pe yeh sab "Variables" tab mein set karne hain (file upload nahi).
# =============================================================================

# Meta Ad Library access token (Graph API Explorer se nikalo — README dekho).
# Agar khaali chhod doge to app DEMO MODE mein chalega (sample data).
META_ACCESS_TOKEN=

# Admin login (single user, session-based auth).
ADMIN_USER=admin
ADMIN_PASS=changeme123

# Flask session signing key — koi bhi lamba random string daalo.
SECRET_KEY=please-change-this-to-a-long-random-string

# Claude (Anthropic) API key — ads ko AI se classify karne ke liye (stance +
# narrative). console.anthropic.com se lo. Khaali ho to AI classification off
# rahega (baaki app normal chalega). Meta token se yeh ALAG hai.
ANTHROPIC_API_KEY=
# Model (default sasta Haiku). Chaaho to claude-sonnet-4-6 ya claude-opus-4-8.
CLASSIFY_MODEL=claude-haiku-4-5

# ---- Optional tuning (defaults theek hain) ----------------------------------
# Data har kitne ghante refresh ho.
REFRESH_HOURS=6

# Graph API version.
GRAPH_API_VERSION=v21.0

# Ek call mein kitne ads (Meta max 50-ish).
META_RESULT_LIMIT=50

# Opponent Page IDs ko code ki jagah env se override karna ho to (JSON):
# OPPONENT_PAGES_JSON={"BJP":["123","456"],"INC":["789"],"SAD":[],"AAP":[]}

# Local dev port (Railway khud PORT inject karta hai).
PORT=5000
